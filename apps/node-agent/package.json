{
  "name": "@a2e/node-agent",
  "version": "1.0.0",
  "description": "A²E Node Agent - GPU node runtime for job execution",
  "main": "dist/index.js",
  "bin": {
    "a2e-agent": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/build.js",
    "build:release": "NODE_ENV=production tsc && node scripts/build.js --release",
    "start": "node dist/index.js",
    "package": "pnpm build:release",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "gpu",
    "node-agent",
    "docker",
    "compute"
  ],
  "author": "Redstone",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "pkg": {
    "targets": [
      "node18-linux-x64",
      "node18-linux-arm64"
    ],
    "outputPath": "dist/bin",
    "assets": [
      "config/**/*"
    ]
  },
  "dependencies": {
    "dockerode": "^4.0.2",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "yaml": "^2.4.1",
    "zod": "^3.22.4",
    "dotenv": "^16.4.5",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.26",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.3",
    "tsx": "^4.7.1",
    "esbuild": "^0.20.2",
    "pkg": "^5.8.1",
    "vitest": "^1.3.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  }
}
