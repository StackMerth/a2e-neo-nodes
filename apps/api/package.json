{
  "name": "@a2e/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "seed:test": "tsx scripts/seed-test-data.ts",
    "seed:test:keep-alive": "tsx scripts/seed-test-data.ts --keep-alive",
    "seed:keep-alive-only": "tsx scripts/seed-test-data.ts --keep-alive-only",
    "seed:templates": "tsx scripts/seed-templates.ts",
    "reputation:recompute": "tsx scripts/reputation-recompute.ts",
    "backfill:co2": "tsx scripts/backfill-co2.ts",
    "referrals:recompute": "tsx scripts/referrals-recompute.ts",
    "referrals:test-flow": "tsx scripts/test-referral-flow.ts",
    "null:payer-key": "tsx scripts/null-payer-key.ts"
  },
  "dependencies": {
    "@a2e/core": "workspace:*",
    "@a2e/database": "workspace:*",
    "@a2e/shared": "workspace:*",
    "@anthropic-ai/sdk": "^0.71.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
