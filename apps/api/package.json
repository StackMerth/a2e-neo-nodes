    "fastify-plugin": "^4.5.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.5",
    "pino": "^8.18.0",
    "socket.io": "^4.7.0",
    "ssh2": "^1.17.0",
    "tweetnacl": "^1.0.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^8.0.0",
    "@types/ssh2": "^1.15.5",
    "pino-pretty": "^10.3.0",
