// ============================================================================
// AUDIT LOGGING (M6)
// ============================================================================

model AuditLog {
  id            String   @id @default(cuid())
  entityType    String   // e.g., "Investment", "Settlement", "Payment"
  entityId      String   // ID of the entity being audited
  action        String   // e.g., "CREATE", "UPDATE", "DELETE", "STATUS_CHANGE"
  previousValue String?  @db.Text  // JSON of previous state
  newValue      String?  @db.Text  // JSON of new state
  actor         String?  // Who made the change (userId, system, etc.)
  actorType     String   @default("SYSTEM") // "USER", "SYSTEM", "API"
  ipAddress     String?  // IP address of the actor
  reason        String?  // Optional reason for the change
  metadata      Json?    // Additional context
  createdAt     DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([actor])
}

// ============================================================================
// IDEMPOTENCY KEYS (M6)
// ============================================================================

model IdempotencyKey {
  id           String   @id  // The idempotency key from request header (IS the primary key)
  endpoint     String   // The endpoint this key was used for
  requestHash  String   // Hash of the request body for verification
  statusCode   Int?     // HTTP status code of the response
  responseBody String?  @db.Text  // Cached response JSON
  expiresAt    DateTime // When this key expires (24 hours)
  createdAt    DateTime @default(now())

  @@index([expiresAt])
}

// ============================================================================
// RECONCILIATION (M6)
// ============================================================================

model PendingReconciliation {
  id               String              @id @default(cuid())
  txHash           String              @unique  // Solana transaction hash
  settlementId     String?
  paymentId        String?
  expectedAmount   Float
  recipientAddress String
  status           ReconciliationStatus @default(PENDING)
  attempts         Int                 @default(0)
  maxAttempts      Int                 @default(10)
  lastAttemptAt    DateTime?
  nextAttemptAt    DateTime?
  errorMessage     String?
  createdAt        DateTime            @default(now())
  resolvedAt       DateTime?

  @@index([status])
  @@index([txHash])
  @@index([nextAttemptAt])
}

enum ReconciliationStatus {
  PENDING    // Waiting to be verified
  VERIFIED   // Transaction confirmed on-chain, DB updated
  FAILED     // Transaction failed or not found
  NOT_FOUND  // Transaction not found after max attempts
  MANUAL     // Requires manual intervention
}

// ============================================================================
// COMPUTE REQUESTS (M6 - Buyer Portal)
// ============================================================================

model ComputeRequest {
  id              String               @id @default(cuid())
  userId          String
  user            User                 @relation(fields: [userId], references: [id])

  // What they need
  gpuTier         GpuTier
  gpuCount        Int                  @default(1)
  durationDays    Int                  @default(30)
  purpose         String?              // What they'll use it for
  // M4.4: optional region constraint. When set, the allocator hard-
  // filters candidate nodes to Node.region === requiredRegion. Null =
  // "Any" (default), meaning region is ignored. Free-form string to
  // match Node.region; common values: us-east-1, us-west-2, eu-west-1,
  // ap-south-1.
  requiredRegion  String?

  // M5.10c: soft operator preference. When the buyer clicks "Rent
  // from this operator" on the marketplace, this is set to that
  // NodeRunner.id. The allocator uses it as a tier-1 sort key (prefer
  // nodes owned by this runner) but does NOT hard-filter - if the
  // preferred operator has zero idle capacity the request still falls
  // back to the general pool on the same tick. Null = no preference.
  preferredOperatorId String?

  // Pricing
  ratePerDay      Float                // Rate at time of request
  totalCost       Float                // gpuCount × ratePerDay × durationDays

  // Payment
  txHash          String?              // Solana transaction hash (or INTERNAL:<id> for balance spend)
  txConfirmed     Boolean              @default(false)
  currency        String               @default("USD")
  // Payment source. USDC = real Solana transfer (txHash is the real
  // on-chain signature). INTERNAL_BALANCE = paid from operator
  // platform balance — txHash is INTERNAL:<computeRequestId> and a
  // matching InternalSpend row records the debit. BUYER_BALANCE =
  // drawn from pre-loaded buyer credit — txHash is BAL:<computeRequestId>
  // and balanceTransactionId links to the SPEND_RENTAL ledger entry.
  paymentSource   PaymentSource        @default(USDC)
  // Wave 3 (AITECH topup): link to the BalanceTransaction row when
  // paymentSource = BUYER_BALANCE. Used by the refund path to credit
  // unused minutes back to the same buyer balance.
  balanceTransactionId String?

  // C2 wave 2: buyer's workload-type declaration. Defaults to MIXED
  // for safety (preserves pre-wave-2 semantics for any pre-existing
  // PENDING/APPROVED rows). When MIXED or TRAINING, the allocator
  // hard-filters out CONSUMER / RTX_4090 / RTX_3090 nodes — those
  // tiers are inference-only.
  workloadType    WorkloadType         @default(MIXED)

  // Status
  status          ComputeRequestStatus @default(PENDING)
  adminNote       String?              // Admin's internal note

  // Allocation — which internal nodes are assigned
  allocatedNodeIds String[]            // Array of Node IDs assigned
  allocationMethod String?             // 'auto' or 'manual'

  // SSH access details (filled when allocated)
  sshHost         String?
  sshPort         Int?
  sshUsername      String?
  // sshPassword stays for legacy rentals provisioned before M2 ephemeral
  // sessions. New rentals must use sshSessionToken below; the password
  // column is kept nullable so existing rows still load. Will be dropped
  // once all pre-M2 rentals are completed or migrated.
  sshPassword     String?

  // M2: ephemeral SSH session token. Issued at allocation, rotated on
  // session end or expiry. Replaces persistent sshPassword for new rentals.
  sshSessionToken          String?
  sshSessionTokenExpiresAt DateTime?

  // Launch-blocker #2: agent-side SSH lifecycle state machine.
  //   PENDING       — allocator created row, agent has not seen it yet
  //   PROVISIONING  — agent received it, useradd + key install in flight
  //   ACTIVE        — Linux user exists, authorized_key installed, ready
  //   TERMINATING   — rental ended, agent received teardown command
  //   TERMINATED    — user deleted, key removed, session done
  //   FAILED        — agent reported error in either direction
  // sshPubKey is the public key written into the rental user's
  // authorized_keys. May be supplied by the buyer (M6 BYO key option)
  // or generated by the platform; null until provisioning starts.
  sshSessionStatus    SshSessionStatus  @default(PENDING)
  sshPubKey           String?
  sshProvisionedAt    DateTime?
  sshTerminatedAt     DateTime?
  sshErrorMessage     String?

  // M2: per-minute billing accumulators. Heartbeat meter rolls minutes into
  // minutesUsed; accruedCost = minutesUsed * ratePerMinute, recomputed on
  // each heartbeat so the buyer dashboard ticker is honest.
  minutesUsed     Int                  @default(0)
  ratePerMinute   Float?
  accruedCost     Float                @default(0)

  // M2: auto-allocator eligibility flags. The rules engine writes flags like
  // "FIRST_TIME_OVER_CEILING" or "DAILY_SPEND_EXCEEDED" so admins can read
  // the hold reason from the Needs Review queue without rerunning the rules.
  eligibilityFlags String[]            @default([])

  // M2: optional template the buyer launched. Pre-warmed on idle nodes so
  // launch-to-Jupyter is sub-30s on warm nodes.
  templateId      String?
  template        Template?            @relation(fields: [templateId], references: [id])

  // M3: pricing tier for the rental.
  //   ON_DEMAND (default) — full price, never preempted, no commitment
  //   SPOT                — discounted (default 40% off via SPOT_DISCOUNT_PCT
  //                         env var), preemptible with 90s notice when
  //                         ON_DEMAND demand needs the capacity
  //   RESERVED            — buyer commits 7/30/90 days, gets 10% discount,
  //                         exempt from preemption, early-terminate refund
  //                         covers only minutes used (not remaining commit)
  tier             ComputeRequestTier  @default(ON_DEMAND)
  // M3: required for RESERVED tier; null for ON_DEMAND/SPOT.
  // Mirrors durationDays for RESERVED but is the thing buyer locked in.
  commitmentDays   Int?

  // M3: checkpoint workspace snapshot. Single checkpoint per rental
  // for now (re-triggering overwrites). checkpointBucketUrl is set
  // by the agent after a successful S3 upload; lastCheckpointId is
  // a cuid that can be passed as restoreCheckpointId on a fresh
  // rental to restore the workspace state.
  //
  // Lifecycle:
  //   NONE       - no checkpoint requested (default)
  //   REQUESTED  - buyer clicked Checkpoint, agent hasn't picked it up
  //   UPLOADING  - agent is packaging + uploading to S3
  //   READY      - upload complete, restorable
  //   FAILED     - last attempt errored (checkpointError has detail)
  checkpointBucketUrl  String?
  lastCheckpointId     String?
  checkpointStatus     CheckpointStatus @default(NONE)
  checkpointRequestedAt DateTime?
  checkpointReadyAt     DateTime?
  checkpointError       String?
  // Optional: passed at request creation to restore from a prior
  // rental's checkpoint. Allocator forwards this to the agent.
  restoreCheckpointId   String?
  // Set by the agent once the restore has been downloaded + unpacked
  // into the buyer's workspace. The heartbeat-response stops surfacing
  // the restore action once this is non-null so the agent never
  // re-applies the same checkpoint twice.
  restoreAppliedAt      DateTime?

  // M3: ratings (one per rental, post-completion).
  rating          Rating?

  // M5.8 / D3: estimated CO2 grams emitted by this rental.
  // Computed by the per-minute meter as
  //   (gpuTier TDP watts * gpuCount * minutesUsed / 60 / 1000)
  //     * region grid intensity (g CO2 / kWh)
  // Region intensity comes from a static lookup table in
  // packages/core/src/carbon-estimator.ts. Honestly approximate,
  // documented inline. Surfaces on the buyer dashboard and monthly
  // billing aggregate; never a paid offset claim.
  co2Grams        Float?

  // M4.7: multi-node cluster (gpuCount > 1). Cluster row owns the
  // WireGuard subnet and master-node pointer; the rental is one
  // logical entity even though the allocator picks N independent
  // nodes underneath. Null on single-GPU rentals.
  clusterId        String?              @unique
  cluster          Cluster?             @relation(fields: [clusterId], references: [id])

  // Timestamps
  requestedAt     DateTime             @default(now())
  approvedAt      DateTime?
  allocatedAt     DateTime?
  activatedAt     DateTime?
  expiresAt       DateTime?            // activatedAt + durationDays
  completedAt     DateTime?

  @@index([userId])
  @@index([status])
  @@index([requestedAt])
  @@index([expiresAt])
  @@index([templateId])
  @@index([tier])
}

// M4.7: Cluster represents a multi-node compute rental. One Cluster
// row per ComputeRequest where gpuCount > 1. The cluster owns its
// WireGuard subnet (a unique /24 carved from the 10.42.0.0/16 pool),
// tracks which node was elected master, and holds the lifecycle
// status so the allocator's atomic transaction can roll back if any
// of the N node assignments fail mid-flight.
model Cluster {
  id               String        @id @default(cuid())
  // Unique back-pointer so the relation works both directions.
  computeRequest   ComputeRequest?
  masterNodeId     String?
  status           ClusterStatus @default(PROVISIONING)
  // A /24 subnet inside 10.42.0.0/16. Each node gets a /30 carved
  // from this subnet so peers route on the WireGuard mesh.
  wireguardSubnet  String
  // Optional: explanation of why the cluster ended up FAILED or was
  // TERMINATED. Surfaced in admin's Compute detail view.
  statusReason     String?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
}

enum ClusterStatus {
  PROVISIONING  // Allocator is wiring nodes + WireGuard configs
  READY         // All nodes have come online with WireGuard peers
  FAILED        // One or more nodes failed to come up; rolled back
  TERMINATED    // Rental ended normally; nodes returned to idle pool
}

enum ComputeRequestStatus {
  PENDING        // Buyer submitted, waiting for admin review
  APPROVED       // Admin approved, waiting for allocation
  ALLOCATED      // Nodes assigned, SSH details ready
  ACTIVE         // Buyer has access, compute is running
  COMPLETED      // Lease expired or manually completed
  CANCELLED      // Buyer cancelled
  REJECTED       // Admin rejected
  WAITLISTED     // M2: held by eligibility rules; admin must approve before allocation
}

// M3: pricing tier for compute requests. Three discrete options buyers
// pick at request time. The routing engine treats tier as a soft tiebreak
// (preferring matching tier on operator inventory); the preemption worker
// uses tier as a hard rule (SPOT preemptible, RESERVED exempt).
enum ComputeRequestTier {
  ON_DEMAND   // default; full price, no preemption, no commitment
  SPOT        // discounted, preemptible with 90s notice
  RESERVED    // commitment-based, preemption-exempt
}

// M3: checkpoint workspace lifecycle. See ComputeRequest.checkpointStatus
// for transitions. Single checkpoint per rental; re-checkpointing
// overwrites the previous one.
enum CheckpointStatus {
  NONE
  REQUESTED
  UPLOADING
  READY
  FAILED
}

// Launch-blocker #2: agent-side SSH lifecycle. Drives the state
// machine in apps/node-agent/src/ssh/session-manager.ts. Transitions
// PENDING -> PROVISIONING -> ACTIVE -> TERMINATING -> TERMINATED
// (or any -> FAILED with sshErrorMessage populated).
enum SshSessionStatus {
  PENDING
  PROVISIONING
  ACTIVE
  TERMINATING
  TERMINATED
  FAILED
}

// ============================================================================
// RATINGS (M3 - Operator Trust)
// ============================================================================
// Buyers rate the operator (NodeRunner) after a rental completes. One
// rating per rental (unique on computeRequestId). Default moderation
// status is PENDING; admins approve/reject before the rating influences
// the operator's reputation score or appears on their public profile.

model Rating {
  id                String                 @id @default(cuid())
  computeRequestId  String                 @unique
  computeRequest    ComputeRequest         @relation(fields: [computeRequestId], references: [id])

  buyerId           String
  buyer             User                   @relation(fields: [buyerId], references: [id])

  nodeRunnerId      String
  nodeRunner        NodeRunner             @relation(fields: [nodeRunnerId], references: [id])

  score             Int                    // 1-5 stars (validated at API)
  comment           String?                // optional, ≤500 chars (validated at API)
  moderationStatus  RatingModerationStatus @default(PENDING)
  moderationNote    String?                // admin's note when rejecting

  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  moderatedAt       DateTime?

  @@index([nodeRunnerId, moderationStatus])
  @@index([buyerId])
  @@index([moderationStatus])
}

enum RatingModerationStatus {
  PENDING    // default; awaiting admin review
  APPROVED   // visible on operator profile, counted in reputation score
  REJECTED   // hidden, NOT counted in reputation score (kept for audit)
}

// ============================================================================
// TEMPLATES (M2 - Buyer Self-Serve)
// ============================================================================
// Pre-built environments the buyer can launch in one click. Admins curate
// the catalog; node-agent pre-warms the top-N most-used images during idle
// time so launch latency stays low. Buyer's selected template is stored on
// ComputeRequest.templateId.

model Template {
  id              String    @id @default(cuid())
  slug            String    @unique // e.g. "pytorch-cuda12.1-jupyter"
  name            String              // human-readable label shown in the picker
  description     String?
  dockerImage     String              // e.g. "pytorch/pytorch:2.3.0-cuda12.1-cudnn8-runtime"
  defaultPort     Int?                // primary service port (Jupyter, Gradio, etc.)
  exposedPorts    Int[]               @default([])
  envVars         Json?               // optional default env vars for this template
  startupCommand  String?             // command run inside the container on launch
  iconUrl         String?
  category        String?             // "training" | "inference" | "blank" | etc.
  popularity      Int       @default(0) // increments on each launch; drives prewarm ranking
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  computeRequests ComputeRequest[]

  @@index([isActive])
  @@index([category])
  @@index([popularity])
}

// ============================================================================
// WITHDRAWAL REQUESTS (Node Runner Earnings)
// ============================================================================

model WithdrawalRequest {
  id              String             @id @default(cuid())
  nodeRunnerId    String
  nodeRunner      NodeRunner         @relation(fields: [nodeRunnerId], references: [id])

  amount          Float              // Amount in USD to withdraw
  walletAddress   String             // Solana wallet to send to
  status          WithdrawalStatus   @default(PENDING)

  // Admin processing
  adminNote       String?
  txHash          String?            // Solana TX hash when transferred
  processedBy     String?            // Admin user ID

  // Timestamps
  requestedAt     DateTime           @default(now())
  approvedAt      DateTime?
  processedAt     DateTime?          // When the transfer was made
  rejectedAt      DateTime?

  @@index([nodeRunnerId])
  @@index([status])
  @@index([requestedAt])
}

enum WithdrawalStatus {
  PENDING        // Node runner submitted, waiting for admin
  APPROVED       // Admin approved, waiting for transfer
  PROCESSING     // Transfer in progress
  COMPLETED      // Funds transferred, TX hash recorded
  REJECTED       // Admin rejected
}

// ============================================================================
// BUYER CREDIT BALANCE  (Wave 3 / borrowed from AITECH topup pattern)
// ============================================================================
// Buyer pre-loads a USD-denominated balance, then rentals draw from it
// instead of requiring a fresh Solana txhash per request. Refunds for
// early-stop rentals credit back to the balance. The custodial wallet
// (admin) still holds the underlying USDC; this table tracks the
// buyer-facing claim on those funds, with every credit/debit recorded
// as a BalanceTransaction so the ledger is fully reconstructable.

model BuyerBalance {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balanceUsd    Float    @default(0)  // current spendable balance
  totalToppedUp Float    @default(0)  // lifetime topup sum (audit)
  totalSpent    Float    @default(0)  // lifetime spend on rentals
  totalRefunded Float    @default(0)  // lifetime refunds credited back
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions  BalanceTransaction[]
}

model BalanceTransaction {
  id           String          @id @default(cuid())
  balanceId    String
  balance      BuyerBalance    @relation(fields: [balanceId], references: [id], onDelete: Cascade)
  type         BalanceTxType
  // Signed amount: positive = credit, negative = debit. Denominated USD.
  amountUsd    Float
  description  String
  // Referenced object id: ComputeRequest.id for SPEND/REFUND_RENTAL,
  // Solana txHash for TOPUP_SOLANA, NULL for admin-credit promos.
  referenceId  String?
  balanceAfter Float           // ledger snapshot after this tx
  createdAt    DateTime        @default(now())

  @@unique([type, referenceId])  // prevents double-credit of the same txHash
  @@index([balanceId, createdAt])
}

enum BalanceTxType {
  TOPUP_SOLANA       // user paid SOL/USDC to admin wallet, credited
  TOPUP_STRIPE       // fiat onramp via Stripe Hosted Checkout
  TOPUP_ADMIN        // manual admin credit (promo, support refund)
  SPEND_RENTAL       // rental cost deducted at request time
  SPEND_DEPLOYMENT   // operator paid for a node deployment from balance
  SPEND_INFERENCE    // per-call inference debit (Track 5 / E1 metering)
  REFUND_RENTAL      // partial refund from early-stop or unused minutes
  REFUND_DEPLOYMENT  // deployment cancelled or rejected — full credit back
  REFUND_INFERENCE   // failed mid-stream / disputed inference call refund
  REFUND_FAILED      // allocator couldn't match — full credit back
  // Track 5 / M0.2: 3-way revenue split destinations. Every SPEND_*
  // debit produces three credit entries: COST_REIMBURSEMENT to the
  // operator (their cost-of-service slice — kept distinct from their
  // profit cut so reconciliation can audit cost vs profit independently),
  // STAKING_POOL_SHARE (25% of net), and TREASURY_SHARE (25% of net).
  // The operator's 50% profit cut continues to use the legacy
  // SPEND_* type for the credit side so existing earnings analytics
  // queries (which sum SPEND_RENTAL credits to compute operator
  // earnings) keep working without a query rewrite.
  COST_REIMBURSEMENT
  STAKING_POOL_SHARE
  TREASURY_SHARE
  // Track 5 / E4: royalty paid to the operator who TRAINED a fine-tuned
  // model when another operator HOSTS inference on it. Funded from the
  // hosting operator's profit slice per the M3.3 split rules.
  ROYALTY_PAYOUT
}

// ============================================================================
// TOKEN BILLING  (Track 5 / E1 — per-token inference metering)
// ============================================================================
// Track 5 sub-phase 3.A ships per-token billing for the upcoming managed
// inference API. Three tables here drive it:
//
//   ModelPricing  — per-model input/output rates the meter charges against
//   TokenUsage    — one row per inference call recording tokens + cost
//   Invoice       — monthly aggregation rolled by the usage-aggregator job
//
// Buyers are debited via balance-service.debitBalance() with type
// SPEND_INFERENCE at the moment the response stream closes; TokenUsage
// rows accumulate as the raw record, and the daily aggregator rolls
// them into Invoice line items so the buyer has an auditable monthly
// statement. Operator revenue share (default 80% per the kickoff
// decision) is paid via the existing Earning pipeline once E2 ships
// the inference router — until then, only the buyer-side debit is
// active.

model ModelPricing {
  // Stable identifier the inference router + meter agree on, e.g.
  // "llama-3.1-70b-instruct" or "stable-diffusion-xl". When E4 (Model
  // Marketplace) ships, this either stays as the canonical pricing
  // source or is folded into Model.pricingId — leaving open both
  // paths for now.
  modelId                    String   @id
  // Both prices stored as USD per ONE MILLION tokens to match
  // industry-standard pricing units (matches OpenAI's published
  // pricing format). The meter divides by 1e6 when computing per-call
  // cost so floating-point error stays well below a cent.
  inputPricePerMillionTokens  Float
  outputPricePerMillionTokens Float
  // Active flag flips off when a model is retired / deprecated.
  // Meter rejects calls against inactive models so we never bill at
  // an old rate.
  isActive                   Boolean  @default(true)
  // Free-form metadata — provider, baseModel, vendor link, etc. JSON
  // so the schema doesn't churn each time we add a new field.
  metadata                   Json?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model TokenUsage {
  id              String   @id @default(cuid())
  // Foreign key to ApiKey is logical only (Prisma relation omitted
  // to keep the inference hot path schema-light); join via raw ID
  // when needed.
  apiKeyId        String
  // Denormalized for fast user-scoped queries (dashboard, invoice
  // aggregator) without a join.
  userId          String
  // Optional trace id from the inference router so a single call
  // can be correlated across logs + ledger + invoice. In 3.A test
  // mode this is null; in 3.B it's the InferenceRequest.id.
  requestId       String?
  // The modelId from ModelPricing the meter charged against.
  model           String
  // Raw token counts emitted by the tokenizer for this call.
  inputTokens     Int
  outputTokens   Int
  // Total cost charged to the buyer in USD. Computed by the meter
  // as (inputTokens * inputPrice + outputTokens * outputPrice) / 1e6.
  // Stored even though it's derivable so per-day rollups don't have
  // to re-multiply.
  costUsd         Float
  // Operator who served the call (the inference worker's nodeRunner).
  // Null in 3.A test mode — only populated once E2 ships the router.
  operatorId      String?
  // Optional latency in ms (request start to last token) for
  // observability + future SLO tracking. Null when not measured.
  latencyMs       Int?
  createdAt       DateTime @default(now())

  // Hot path indexes for the aggregator + dashboards.
  @@index([apiKeyId, createdAt])
  @@index([userId, createdAt])
  @@index([model, createdAt])
}

model Invoice {
  id          String        @id @default(cuid())
  userId      String
  // YYYY-MM period the invoice covers. One invoice per user per
  // month — enforced by the unique below.
  period      String
  // JSON breakdown of line items: [{ model, inputTokens, outputTokens, costUsd }, ...]
  // Built by the usage-aggregator from TokenUsage rows for the period.
  lineItems   Json
  totalUsd    Float
  status      InvoiceStatus @default(DRAFT)
  // Used by the aggregator to set a sensible "statement due" date
  // for accounting; payment is already debited live via debitBalance,
  // so this is informational rather than a hard deadline.
  dueAt       DateTime?
  // Set when the SENT email goes out (or the buyer marks acknowledged).
  sentAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([userId, period])
  @@index([status, dueAt])
}

enum InvoiceStatus {
  DRAFT      // current open period, aggregator still adding line items
  FINALIZED  // period closed, statement ready, not yet delivered
  SENT       // statement email delivered to the buyer
  VOID       // admin reversal (refund, dispute, fraud)
}

// ============================================================================
// WEB PUSH (VAPID) SUBSCRIPTIONS  (Phase 5 / wave-3 notifications upgrade)
// ============================================================================
// Browsers register a push subscription with the Push Service (Mozilla
// Autopush, Firebase Cloud Messaging, etc.) and hand the resulting
// endpoint + keys to the app. Server side, we store one row per
// (user, endpoint) so a user with two devices (laptop + phone PWA)
// gets the notification on both. Per W3C Push API spec, p256dh +
// auth are base64url-encoded; we keep them as opaque strings.

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Globally-unique URL the Push Service issued; primary lookup key.
  endpoint  String   @unique

  // P-256 public key + 16-byte auth secret. Used by web-push to
  // encrypt the payload to the subscriber. Opaque to us.
  p256dh    String
  auth      String

  // User-Agent string at subscribe time (best-effort device label).
  // Not used for routing — purely so the operator can see which
  // device they registered from when revoking a subscription.
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Last successful push send. Lets a cleanup job retire endpoints
  // that have been gone for a long time (e.g., 60+ days of 410s).
  lastSentAt DateTime?

  @@index([userId])
}

// ============================================================================
// COST OF SERVICE  (Track 5 / 3.0 — Model C revenue split foundation)
// ============================================================================
// Under Model C every revenue debit (rental, deployment, inference) splits
// 50/25/25 of NET profit between operator, staking pool, and treasury. Net
// profit = gross revenue − operator's cost-of-service. Cost-of-service is
// computed deterministically from the operator's declared hardware, not
// self-declared by the operator (gaming-resistant by design).
//
//   GpuCostBaseline  — per-SKU constants (kWh draw, hardware amortization,
//                      bandwidth + overhead per hour). Seeded from public
//                      specs.
//   PowerRate        — per-region kWh price. Seeded with a single GLOBAL
//                      row at $0.12/kWh; regional rows added when regional
//                      inference at install ships.
//
// Cost-of-service formula (services/revenue/cost-of-service.ts):
//   hourlyCost = (gpu.kwhDraw * region.usdPerKwh)
//              + gpu.hardwareAmortHourly
//              + gpu.bandwidthCostHourly
//              + gpu.overheadHourly
//   periodCost = hourlyCost * (durationSeconds / 3600)

model GpuCostBaseline {
  // Normalized SKU key (e.g. "H100_80GB", "RTX_4090", "A100_40GB").
  // Matched against Node.declaredGpuSku at split time. When no row
  // matches, the cost-of-service service falls back to a tier-default
  // (one row per GpuTier value also seeded under names like
  // "TIER_DEFAULT_H100", "TIER_DEFAULT_CONSUMER").
  gpuSku                String  @id
  // Free-form family label for grouping in admin UIs ("Hopper", "Ada",
  // "Ampere", "Blackwell", "Consumer"). Not used by the cost formula.
  gpuFamily             String
  // Sustained power draw at typical inference/training load, in kWh
  // (kilowatt-hours per hour, i.e. kW). 4090 ~0.45, A100-80 ~0.4,
  // H100 ~0.7, B200 ~1.0. Multiplied by PowerRate.usdPerKwh to get
  // electricity cost per hour.
  kwhDraw               Float
  // Hardware amortization per hour. Computed as (purchase price /
  // expected service life in hours). Seeded from public retail prices
  // and a 3-year / 24x7 amortization schedule (~26280 hours). Admin
  // can override per SKU as market prices shift.
  hardwareAmortHourly   Float
  // Bandwidth + colo overhead per hour, in USD. Covers network egress
  // share, cooling, rack space, etc. Lower for residential operators
  // (~$0.02), higher for datacenter (~$0.30+).
  bandwidthCostHourly   Float
  // Catch-all platform overhead per hour (monitoring, support, SLA
  // reserve). Default $0.05/hour. Lets us nudge cost-of-service up or
  // down without re-fitting individual components.
  overheadHourly        Float   @default(0.05)
  // Pre-computed sum of the above at GLOBAL power rate, for fast
  // admin / dashboard display. Recomputed by the seed/update path;
  // the cost-of-service service does NOT read this — it always
  // recomputes against the live PowerRate row so a power-rate change
  // takes effect immediately.
  totalCostHourlyGlobal Float
  // Free-form note (datasheet link, sourcing decision, etc.) for the
  // admin UI.
  notes                 String?
  isActive              Boolean @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model PowerRate {
  // Region bucket. Initial seed has one row: "GLOBAL" at $0.12/kWh.
  // Per-region rows ("US", "EU", "ASIA", "OTHER") added when M0.1+
  // backfills detect operator regions from BYOG install IPs.
  region     String   @id
  // USD per kWh charged at this region's residential/datacenter
  // average. Used by the cost-of-service service to multiply against
  // GpuCostBaseline.kwhDraw.
  usdPerKwh  Float
  // Free-form note (data source, last-checked date, etc.).
  notes      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============================================================================
// REVENUE SHARE AUDIT  (Track 5 / M0.2)
// ============================================================================
// Every call to splitRevenue() writes one row here AND credits two
// BalanceTransaction entries (STAKING_POOL_SHARE + TREASURY_SHARE) to
// the virtual system users. The caller (M0.3 rental meter retrofit,
// M0.4 deployment retrofit, M1.1 inference meter retrofit) uses the
// returned operatorTotalUsd to write into the Earning table (or
// equivalent operator-credit path) so the operator's existing earnings
// flow stays intact, just with a smaller number.
//
// The reconciliation script (M0.5) reads this table to verify, for any
// rental / deployment / inference call, that:
//   operatorTotalUsd + stakingShareUsd + treasuryShareUsd == grossUsd
//   (operatorTotalUsd - costUsd) == 0.5 * netUsd
// A mismatch indicates a non-3-way path was missed during the retrofit.
//
// One row per referenceId is enforced by @@unique so a retry of a
// splitRevenue call is a no-op — the existing row is returned and no
// double-credit can land in staking/treasury.

model RevenueShareEntry {
  id              String   @id @default(cuid())
  // Tags which revenue path produced this split. Must match the
  // BalanceTxType value the buyer was debited with so reconciliation
  // can join the two ledgers.
  sourceTxType    String
  // Stable identifier the buyer's debit also carries. ComputeRequest.id
  // for rentals, deployment id for deployments, inference request id
  // for SPEND_INFERENCE.
  referenceId     String
  // Gross revenue collected from the buyer (= buyer's SPEND_* debit).
  grossUsd        Float
  // Cost-of-service reimbursed to operator first (cost-of-service.ts
  // output at split time).
  costUsd         Float
  // Net = max(0, gross - cost). Stored for the audit even though
  // derivable, since cost-of-service may change retroactively if a
  // GpuCostBaseline row is edited.
  netUsd          Float
  // What the operator actually received (cost + 0.5 * net at the time
  // of this split). The retrofit caller uses this to credit the
  // operator's Earning row.
  operatorTotalUsd Float
  stakingShareUsd Float
  treasuryShareUsd Float
  // The operator's User id, for cross-checking with the Earning table.
  operatorUserId  String
  // Snapshot of the kill switch state at split time. Lets the audit
  // distinguish "OFF — operator got full gross via legacy path" from
  // "ON — operator got cost + 0.5 * net via the new path". When OFF,
  // stakingShareUsd and treasuryShareUsd will be 0 and operatorTotalUsd
  // will equal grossUsd.
  splitEnabled    Boolean
  createdAt       DateTime @default(now())

  @@unique([referenceId])
  @@index([sourceTxType, createdAt])
  @@index([operatorUserId, createdAt])
}
