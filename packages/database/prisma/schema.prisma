// A²E Engine Database Schema
// TokenOS Arbitrage & Orchestration Engine

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum GpuTier {
  H100
  H200
  B200
  B300
  GB300
  OTHER
}

enum NodeType {
  PROVISIONED // TokenOS provisions from data center
  BYOG        // Bring Your Own GPU
}

enum NodeStatus {
  ONLINE
  DEGRADED
  OFFLINE
  PAUSED
  MAINTENANCE
}

enum JobStatus {
  PENDING    // Job submitted, waiting for routing
  ROUTING    // A²E is deciding where to route
  ASSIGNED   // Assigned to a node/market
  RUNNING    // Job is executing
  COMPLETED  // Job finished successfully
  FAILED     // Job failed
  CANCELLED  // Job was cancelled
}

enum Market {
  INTERNAL   // TokenOS internal (premium retail rate)
  AKASH      // Akash Network (external)
  IONET      // IO.net (external)
  VASTAI     // Vast.ai (external)
}

enum JobSource {
  INTERNAL   // Job originated from TokenOS internal demand (existing behavior)
  EXTERNAL   // Job arrived via external market (Akash/IO.net/Vast.ai deployment)
}

enum ExternalDeploymentStatus {
  PENDING      // Creation initiated, awaiting confirmation from market
  ACTIVE       // Running on external market
  TERMINATING  // Delist in progress (SAFE mode grace window)
  TERMINATED   // Successfully terminated
  FAILED       // Creation or runtime failure
}

enum ExternalTerminationMode {
  SAFE   // Waited for workload completion or grace window
  FORCE  // Terminated immediately, forfeit in-flight earnings
}

// ============================================================================
// USERS & AUTH (M6)
// ============================================================================

enum UserRole {
  NODE_RUNNER
  COMPUTE_BUYER
  CUSTOMER       // Legacy — use COMPUTE_BUYER for new buyers
  ADMIN
}

enum NotificationType {
  NODE_OFFLINE
  PAYOUT_SENT
  JOB_COMPLETED
  JOB_FAILED
  INVESTMENT_CONFIRMED
  INVESTMENT_PROVISIONED
  DEPLOYMENT_REQUESTED
  DEPLOYMENT_STARTED
  DEPLOYMENT_COMPLETED
  COMPUTE_REQUEST_NEW
  COMPUTE_REQUEST_APPROVED
  COMPUTE_ALLOCATED
  COMPUTE_ACTIVE
  COMPUTE_EXPIRING
  COMPUTE_COMPLETED
  COMPUTE_REJECTED
  COMPUTE_REQUEST_HELD // M2: held by auto-allocator pending admin review
  WITHDRAWAL_REQUESTED
  WITHDRAWAL_APPROVED
  WITHDRAWAL_PROCESSING
  WITHDRAWAL_COMPLETED
  WITHDRAWAL_REJECTED
}

model User {
  id               String    @id @default(cuid())
  email            String?   @unique
  walletAddress    String?   @unique
  passwordHash     String?
  role             UserRole  @default(NODE_RUNNER)
  emailVerified    Boolean   @default(false)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?

  // Email verification
  emailVerificationToken  String?
  emailVerificationExpiry DateTime?

  // Password reset
  passwordResetToken  String?
  passwordResetExpiry DateTime?

  // M2: buyer quotas. Cap concurrent active rentals and daily spend so a
  // compromised account can't drain inventory or burn the buyer's wallet.
  // Defaults are generous enough to be invisible for legitimate users;
  // admin can tune per-user from the dashboard.
  maxConcurrentRentals  Int     @default(10)
  maxDailySpendUsd      Float   @default(10000)

  // M2: trust score for the auto-allocator. Increments on every successfully
  // completed rental (full cycle, no chargeback). Used by the eligibility
  // rules engine to decide whether a request auto-approves or holds for
  // admin review.
  successfulRentalCount Int     @default(0)
  lastRentalAt          DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  nodeRunner       NodeRunner?
  notifications    Notification[]
  refreshTokens    RefreshToken[]
  computeRequests  ComputeRequest[]
  apiKeys          ApiKey[]

  @@index([role])
}

model ApiKey {
  id          String    @id @default(cuid())
  key         String    @unique
  name        String
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions String[]  @default(["compute:read", "compute:write"])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([key])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ============================================================================
// NODE RUNNERS (Investors)
// ============================================================================

model NodeRunner {
  id            String   @id @default(cuid())
  name          String               // Display name
  email         String?  @unique     // Contact email
  walletAddress String   @unique     // Solana wallet for payouts

  // Link to User account (for portal login)
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id])

  // Payout preferences
  payoutThreshold  Float    @default(10.0)   // Minimum USD to trigger payout
  payoutFrequency  String   @default("WEEKLY") // DAILY, WEEKLY, MONTHLY
  payoutDayOfWeek  Int?     // 0=Sunday, 1=Monday, etc. (for WEEKLY)
  payoutDayOfMonth Int?     // 1-28 (for MONTHLY)

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  nodes              Node[]
  investments        Investment[]
  withdrawalRequests WithdrawalRequest[]

  @@index([walletAddress])
  @@index([userId])
}

model Investment {
  id            String           @id @default(cuid())
  nodeRunnerId  String
  nodeRunner    NodeRunner       @relation(fields: [nodeRunnerId], references: [id])

  // Investment details
  amount        Float            // Amount paid (e.g., 2500)
  currency      String           @default("USD")
  nodeCount     Int              @default(1)

  // Crypto payment details
  cryptoAmount  Float?           // Amount in crypto (e.g., SOL)
  cryptoCurrency String?         // e.g., "SOL", "USDC"
  txHash        String?          // Solana transaction hash
  txConfirmed   Boolean          @default(false)

  // What was purchased
  nodeId        String?          // Linked to node once provisioned
  gpuTier       GpuTier          // GPU tier purchased

  // Status
  status        InvestmentStatus @default(PENDING)

  // Deployment tracking (node runner → admin → data center flow)
  deploymentNote String?         // Node runner's note for the request
  sshHost        String?         // SSH host (admin fills in from data center)
  sshPort        Int?            // SSH port (default 22)
  sshUsername    String?          // SSH username
  provisionJobId String?         // Linked ProvisionJob once provisioning starts

  // Timestamps
  createdAt     DateTime         @default(now())
  confirmedAt   DateTime?        // When payment was confirmed
  deploymentRequestedAt DateTime? // When node runner requested deployment
  provisionedAt DateTime?        // When node was provisioned

  @@index([nodeRunnerId])
  @@index([status])
  @@index([txHash])
}

enum InvestmentStatus {
  PENDING                // Waiting for payment
  PAID                   // Payment received (admin-created flow)
  DEPLOYMENT_REQUESTED   // Node runner requested deployment, waiting for admin
  DEPLOYING              // Admin submitted SSH details, provisioning in progress
  PROVISIONED            // Node is set up and running
  CANCELLED              // Investment cancelled/refunded
}

// ============================================================================
// NODES
// ============================================================================

model Node {
  id            String     @id @default(cuid())
  walletAddress String     @unique
  gpuTier       GpuTier
  nodeType      NodeType
  status        NodeStatus @default(ONLINE)
  region        String?

  // Node Runner (owner/investor)
  nodeRunnerId  String?
  nodeRunner    NodeRunner? @relation(fields: [nodeRunnerId], references: [id])

  // Custom GPU info (used when gpuTier = OTHER)
  customGpuModel    String?   // e.g. "A100", "RTX 4090", "L40S"
  customRatePerHour Float?    // Custom hourly rate for OTHER tier
  customRatePerDay  Float?    // Custom daily rate for OTHER tier

  // Agent authentication
  apiKey        String?    @unique  // Node-specific API key for agent auth

  // Deletion flag - when true, agent will receive UNINSTALL command on next heartbeat
  pendingDeletion Boolean  @default(false)

  // Compute buyer allocation
  assignedComputeRequestId String?  // Which compute request this node is serving

  // Agent information
  agentVersion  String?
  currentJobId  String?
  lastCommandAt DateTime?

  // Health tracking
  lastHeartbeat DateTime   @default(now())
  missedBeats   Int        @default(0)

  // Timestamps
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  jobs                Job[]
  earnings            Earning[]
  heartbeats          Heartbeat[]
  settlements         Settlement[]
  infrastructureCosts InfrastructureCost[]
  provisionJob        ProvisionJob?
  externalDeployments ExternalDeployment[]

  @@index([status])
  @@index([gpuTier])
  @@index([lastHeartbeat])
  @@index([nodeRunnerId])
}

model Heartbeat {
  id          String   @id @default(cuid())
  nodeId      String
  node        Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  // GPU Metrics (optional)
  gpuUtilization  Float?   // 0-100%
  gpuTemperature  Float?   // Celsius
  gpuMemoryUsed   Float?   // GB
  gpuMemoryTotal  Float?   // GB

  timestamp   DateTime @default(now())

  @@index([nodeId, timestamp])
}

// ============================================================================
// JOBS
// ============================================================================

model Job {
  id            String    @id @default(cuid())
  deploymentId  String    // External reference from TokenOS

  // Assignment
  nodeId        String?
  node          Node?     @relation(fields: [nodeId], references: [id])

  // Routing decision
  market        Market?
  ratePerHour   Float?

  // Job details
  gpuTier       GpuTier
  status        JobStatus @default(PENDING)

  // Origin — whether this job came from internal TokenOS demand or an external market
  source               JobSource           @default(INTERNAL)
  externalDeploymentId String?
  externalDeployment   ExternalDeployment? @relation(fields: [externalDeploymentId], references: [id])

  // Timing
  requestedAt   DateTime  @default(now())
  routedAt      DateTime?
  startedAt     DateTime?
  completedAt   DateTime?

  // Duration and earnings
  durationSeconds Int?
  earnings        Float?    // Revenue from this job
  cost            Float?    // Cost to execute (market rate or external fees)
  profit          Float?    // earnings - cost

  // Error tracking
  errorMessage  String?
  retryCount    Int       @default(0)

  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  routingLog    RoutingLog?

  @@index([status])
  @@index([deploymentId])
  @@index([nodeId])
  @@index([market])
  @@index([requestedAt])
  @@index([source])
  @@index([externalDeploymentId])
}

// ============================================================================
// ROUTING DECISIONS
// ============================================================================

model RoutingLog {
  id              String   @id @default(cuid())
  jobId           String   @unique
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // Decision
  selectedMarket  Market
  selectedRate    Float    // Rate per hour that was selected

  // Rates at decision time
  internalRate    Float?
  akashRate       Float?
  ionetRate       Float?
  vastaiRate      Float?

  // Yield floor
  yieldFloor          Float
  yieldFloorApplied   Boolean  @default(false)

  // Reasoning
  reason          String   // Human-readable explanation

  // Decision metadata
  decisionTimeMs  Int?     // How long the decision took

  timestamp       DateTime @default(now())

  @@index([selectedMarket])
  @@index([timestamp])
}

// ============================================================================
// MARKET RATES
// ============================================================================

model MarketRate {
  id          String   @id @default(cuid())
  market      Market
  gpuTier     GpuTier
  ratePerHour Float
  ratePerDay  Float
  available   Boolean  @default(true)

  fetchedAt   DateTime @default(now())

  @@unique([market, gpuTier])
  @@index([market, gpuTier, fetchedAt])
}

model MarketRateHistory {
  id          String   @id @default(cuid())
  market      Market
  gpuTier     GpuTier
  ratePerHour Float
  ratePerDay  Float

  fetchedAt   DateTime @default(now())

  @@index([market, gpuTier, fetchedAt])
}

// ============================================================================
// EARNINGS
// ============================================================================

model Earning {
  id            String   @id @default(cuid())
  nodeId        String
  node          Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  date          DateTime @db.Date
  market        Market

  gpuSeconds    Int      @default(0)
  earnings      Float    @default(0)
  jobCount      Int      @default(0)

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([nodeId, date, market])
  @@index([nodeId, date])
  @@index([date])
}

// ============================================================================
// CONFIGURATION
// ============================================================================

model Config {
  key       String   @id
  value     String

  updatedAt DateTime @updatedAt
}

model YieldFloor {
  gpuTier     GpuTier  @id
  ratePerHour Float
  ratePerDay  Float

  updatedAt   DateTime @updatedAt
}

model MarketConfig {
  market      Market   @id
  enabled     Boolean  @default(true)
  priority    Int      @default(0)  // Higher = preferred when rates equal

  // API configuration (stored encrypted in practice)
  apiEndpoint String?

  updatedAt   DateTime @updatedAt
}

// ============================================================================
// EXTERNAL MARKET OVERFLOW (M7)
// ============================================================================

model ExternalDeployment {
  id              String                   @id @default(cuid())
  nodeId          String
  node            Node                     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  market          Market                   // AKASH | IONET | VASTAI (never INTERNAL)
  externalId      String                   // Deployment ID on the external platform
  status          ExternalDeploymentStatus @default(PENDING)

  // Economics
  ratePerHour         Float                // Rate we expect to earn per hour
  costAccumulated     Float                @default(0) // Running cost in USD
  earningsAccumulated Float                @default(0) // Running earnings in USD

  // Lifecycle
  createdAt       DateTime                 @default(now())
  terminatedAt    DateTime?
  lastCheckedAt   DateTime                 @default(now())

  // Termination tracking
  terminationMode   ExternalTerminationMode?
  terminationReason String?

  // Relations — jobs that executed on this external deployment
  jobs            Job[]

  @@index([nodeId])
  @@index([market])
  @@index([status])
  @@index([externalId])
}

model OverflowConfig {
  id                      String   @id @default("singleton")  // always "singleton"
  enabled                 Boolean  @default(false)             // overflow off by default
  simulationMode          Boolean  @default(true)              // simulated adapters by default until credentials arrive

  idleThresholdMinutes    Int      @default(10)                // how long idle before listing externally
  demandThresholdPercent  Int      @default(80)                // % of nodes busy triggers delist
  marginProtectionPercent Int      @default(15)                // minimum margin above cost floor

  gracePeriodSeconds      Int      @default(300)               // SAFE termination grace window (5 min)

  // Preferred market order (JSON array of Market enum values as strings)
  preferredMarkets        String   @default("[\"AKASH\",\"IONET\",\"VASTAI\"]")

  updatedAt               DateTime @updatedAt
}

// ============================================================================
// SETTLEMENTS (M4)
// ============================================================================

model Settlement {
  id            String           @id @default(cuid())
  nodeId        String
  walletAddress String
  amount        Float
  currency      String           @default("USD")
  status        SettlementStatus @default(PENDING)
  periodStart   DateTime
  periodEnd     DateTime
  jobCount      Int
  txHash        String?
  txConfirmed   Boolean          @default(false)
  errorMessage  String?

  // Retry handling
  retryCount    Int              @default(0)
  maxRetries    Int              @default(3)
  lastRetryAt   DateTime?
  nextRetryAt   DateTime?

  createdAt     DateTime         @default(now())
  processedAt   DateTime?

  node          Node             @relation(fields: [nodeId], references: [id])
  items         SettlementItem[]

  @@index([nodeId])
  @@index([status])
  @@index([createdAt])
}

model SettlementItem {
  id           String     @id @default(cuid())
  settlementId String
  jobId        String
  amount       Float

  settlement   Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
}

model SettlementConfig {
  id              String   @id @default("default")
  period          String   @default("WEEKLY")   // DAILY, WEEKLY, MONTHLY
  minimumPayout   Float    @default(10)
  dayOfWeek       Int?     @default(1)          // 0=Sunday, 1=Monday, etc.
  dayOfMonth      Int?                          // 1-28 for monthly
  hour            Int      @default(9)          // Hour of day to run (0-23)

  // Auto-scheduling
  autoSchedule    Boolean  @default(false)      // Enable automatic settlements
  lastScheduledAt DateTime?                     // Last time scheduler ran

  // Solana config
  solanaRpcUrl    String?
  payerPrivateKey String?
  usdcMint        String?
  updatedAt       DateTime @updatedAt
}

// ============================================================================
// INFRASTRUCTURE COSTS (M4)
// ============================================================================

model InfrastructureCost {
  id          String   @id @default(cuid())
  nodeId      String?
  category    String
  amount      Float
  currency    String   @default("USD")
  description String?
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())

  node        Node?    @relation(fields: [nodeId], references: [id])

  @@index([nodeId])
  @@index([category])
  @@index([periodStart, periodEnd])
}

enum SettlementStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================================================
// PAYMENTS (M4)
// ============================================================================

model Payment {
  id            String        @id @default(cuid())
  settlementId  String
  amount        Float
  currency      String        @default("USDC")
  recipientAddress String

  // Payment execution
  status        PaymentStatus @default(PENDING)
  txHash        String?
  txConfirmed   Boolean       @default(false)
  confirmations Int           @default(0)

  // Dev mode tracking
  isDevMode     Boolean       @default(false)

  // Error handling
  errorMessage  String?
  retryCount    Int           @default(0)
  maxRetries    Int           @default(3)

  // Timestamps
  createdAt     DateTime      @default(now())
  processedAt   DateTime?
  confirmedAt   DateTime?

  @@index([settlementId])
  @@index([status])
  @@index([txHash])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SENT
  CONFIRMED
  FAILED
}

// ============================================================================
// NODE PROVISIONING (M5)
// ============================================================================

model ProvisionJob {
  id            String          @id @default(cuid())
  status        ProvisionStatus @default(PENDING)

  // Connection details (credentials NOT stored - only in memory during job)
  host          String
  port          Int             @default(22)
  username      String

  // Node configuration
  gpuTier       GpuTier
  nodeName      String?
  region        String?

  // Custom GPU info (used when gpuTier = OTHER)
  customGpuModel    String?
  customRatePerHour Float?
  customRatePerDay  Float?

  // API key for the provisioned agent
  apiKey        String?         @unique

  // Progress tracking
  currentStep   Int             @default(0)
  totalSteps    Int             @default(7)
  currentAction String?
  logs          Json            @default("[]")

  // Result
  nodeId        String?         @unique
  node          Node?           @relation(fields: [nodeId], references: [id])
  error         String?

  // Timestamps
  createdAt     DateTime        @default(now())
  startedAt     DateTime?
  completedAt   DateTime?

  @@index([status])
  @@index([createdAt])
}

enum ProvisionStatus {
  PENDING
  CONNECTING
  VERIFYING
  DOWNLOADING
  INSTALLING
  CONFIGURING
  STARTING
  WAITING_REGISTRATION
  COMPLETED
  FAILED
  CANCELLED
}

// ============================================================================
// AUDIT LOGGING (M6)
// ============================================================================

model AuditLog {
  id            String   @id @default(cuid())
  entityType    String   // e.g., "Investment", "Settlement", "Payment"
  entityId      String   // ID of the entity being audited
  action        String   // e.g., "CREATE", "UPDATE", "DELETE", "STATUS_CHANGE"
  previousValue String?  @db.Text  // JSON of previous state
  newValue      String?  @db.Text  // JSON of new state
  actor         String?  // Who made the change (userId, system, etc.)
  actorType     String   @default("SYSTEM") // "USER", "SYSTEM", "API"
  ipAddress     String?  // IP address of the actor
  reason        String?  // Optional reason for the change
  metadata      Json?    // Additional context
  createdAt     DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([actor])
}

// ============================================================================
// IDEMPOTENCY KEYS (M6)
// ============================================================================

model IdempotencyKey {
  id           String   @id  // The idempotency key from request header (IS the primary key)
  endpoint     String   // The endpoint this key was used for
  requestHash  String   // Hash of the request body for verification
  statusCode   Int?     // HTTP status code of the response
  responseBody String?  @db.Text  // Cached response JSON
  expiresAt    DateTime // When this key expires (24 hours)
  createdAt    DateTime @default(now())

  @@index([expiresAt])
}

// ============================================================================
// RECONCILIATION (M6)
// ============================================================================

model PendingReconciliation {
  id               String              @id @default(cuid())
  txHash           String              @unique  // Solana transaction hash
  settlementId     String?
  paymentId        String?
  expectedAmount   Float
  recipientAddress String
  status           ReconciliationStatus @default(PENDING)
  attempts         Int                 @default(0)
  maxAttempts      Int                 @default(10)
  lastAttemptAt    DateTime?
  nextAttemptAt    DateTime?
  errorMessage     String?
  createdAt        DateTime            @default(now())
  resolvedAt       DateTime?

  @@index([status])
  @@index([txHash])
  @@index([nextAttemptAt])
}

enum ReconciliationStatus {
  PENDING    // Waiting to be verified
  VERIFIED   // Transaction confirmed on-chain, DB updated
  FAILED     // Transaction failed or not found
  NOT_FOUND  // Transaction not found after max attempts
  MANUAL     // Requires manual intervention
}

// ============================================================================
// COMPUTE REQUESTS (M6 - Buyer Portal)
// ============================================================================

model ComputeRequest {
  id              String               @id @default(cuid())
  userId          String
  user            User                 @relation(fields: [userId], references: [id])

  // What they need
  gpuTier         GpuTier
  gpuCount        Int                  @default(1)
  durationDays    Int                  @default(30)
  purpose         String?              // What they'll use it for

  // Pricing
  ratePerDay      Float                // Rate at time of request
  totalCost       Float                // gpuCount × ratePerDay × durationDays

  // Payment
  txHash          String?              // Solana transaction hash
  txConfirmed     Boolean              @default(false)
  currency        String               @default("USD")

  // Status
  status          ComputeRequestStatus @default(PENDING)
  adminNote       String?              // Admin's internal note

  // Allocation — which internal nodes are assigned
  allocatedNodeIds String[]            // Array of Node IDs assigned
  allocationMethod String?             // 'auto' or 'manual'

  // SSH access details (filled when allocated)
  sshHost         String?
  sshPort         Int?
  sshUsername      String?
  // sshPassword stays for legacy rentals provisioned before M2 ephemeral
  // sessions. New rentals must use sshSessionToken below; the password
  // column is kept nullable so existing rows still load. Will be dropped
  // once all pre-M2 rentals are completed or migrated.
  sshPassword     String?

  // M2: ephemeral SSH session token. Issued at allocation, rotated on
  // session end or expiry. Replaces persistent sshPassword for new rentals.
  sshSessionToken          String?
  sshSessionTokenExpiresAt DateTime?

  // M2: per-minute billing accumulators. Heartbeat meter rolls minutes into
  // minutesUsed; accruedCost = minutesUsed * ratePerMinute, recomputed on
  // each heartbeat so the buyer dashboard ticker is honest.
  minutesUsed     Int                  @default(0)
  ratePerMinute   Float?
  accruedCost     Float                @default(0)

  // M2: auto-allocator eligibility flags. The rules engine writes flags like
  // "FIRST_TIME_OVER_CEILING" or "DAILY_SPEND_EXCEEDED" so admins can read
  // the hold reason from the Needs Review queue without rerunning the rules.
  eligibilityFlags String[]            @default([])

  // M2: optional template the buyer launched. Pre-warmed on idle nodes so
  // launch-to-Jupyter is sub-30s on warm nodes.
  templateId      String?
  template        Template?            @relation(fields: [templateId], references: [id])

  // Timestamps
  requestedAt     DateTime             @default(now())
  approvedAt      DateTime?
  allocatedAt     DateTime?
  activatedAt     DateTime?
  expiresAt       DateTime?            // activatedAt + durationDays
  completedAt     DateTime?

  @@index([userId])
  @@index([status])
  @@index([requestedAt])
  @@index([expiresAt])
  @@index([templateId])
}

enum ComputeRequestStatus {
  PENDING        // Buyer submitted, waiting for admin review
  APPROVED       // Admin approved, waiting for allocation
  ALLOCATED      // Nodes assigned, SSH details ready
  ACTIVE         // Buyer has access, compute is running
  COMPLETED      // Lease expired or manually completed
  CANCELLED      // Buyer cancelled
  REJECTED       // Admin rejected
  WAITLISTED     // M2: held by eligibility rules; admin must approve before allocation
}

// ============================================================================
// TEMPLATES (M2 - Buyer Self-Serve)
// ============================================================================
// Pre-built environments the buyer can launch in one click. Admins curate
// the catalog; node-agent pre-warms the top-N most-used images during idle
// time so launch latency stays low. Buyer's selected template is stored on
// ComputeRequest.templateId.

model Template {
  id              String    @id @default(cuid())
  slug            String    @unique // e.g. "pytorch-cuda12.1-jupyter"
  name            String              // human-readable label shown in the picker
  description     String?
  dockerImage     String              // e.g. "pytorch/pytorch:2.3.0-cuda12.1-cudnn8-runtime"
  defaultPort     Int?                // primary service port (Jupyter, Gradio, etc.)
  exposedPorts    Int[]               @default([])
  envVars         Json?               // optional default env vars for this template
  startupCommand  String?             // command run inside the container on launch
  iconUrl         String?
  category        String?             // "training" | "inference" | "blank" | etc.
  popularity      Int       @default(0) // increments on each launch; drives prewarm ranking
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  computeRequests ComputeRequest[]

  @@index([isActive])
  @@index([category])
  @@index([popularity])
}

// ============================================================================
// WITHDRAWAL REQUESTS (Node Runner Earnings)
// ============================================================================

model WithdrawalRequest {
  id              String             @id @default(cuid())
  nodeRunnerId    String
  nodeRunner      NodeRunner         @relation(fields: [nodeRunnerId], references: [id])

  amount          Float              // Amount in USD to withdraw
  walletAddress   String             // Solana wallet to send to
  status          WithdrawalStatus   @default(PENDING)

  // Admin processing
  adminNote       String?
  txHash          String?            // Solana TX hash when transferred
  processedBy     String?            // Admin user ID

  // Timestamps
  requestedAt     DateTime           @default(now())
  approvedAt      DateTime?
  processedAt     DateTime?          // When the transfer was made
  rejectedAt      DateTime?

  @@index([nodeRunnerId])
  @@index([status])
  @@index([requestedAt])
}

enum WithdrawalStatus {
  PENDING        // Node runner submitted, waiting for admin
  APPROVED       // Admin approved, waiting for transfer
  PROCESSING     // Transfer in progress
  COMPLETED      // Funds transferred, TX hash recorded
  REJECTED       // Admin rejected
}
