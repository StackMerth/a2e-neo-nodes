// A²E Engine Database Schema
// TokenOS Arbitrage & Orchestration Engine

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum GpuTier {
  H100
  H200
  // L40S: NVIDIA data-center inference / mid-training card. Mid-tier
  // datacenter SKU (between consumer RTX and the H/B-series). Counts
  // as a data-center tier for allocator routing — eligible for every
  // workload type, NOT subject to the consumer inference-only filter.
  L40S
  B200
  B300
  GB300
  OTHER
  // C2 wave 2: consumer / prosumer GPU tiers. CONSUMER is a catchall
  // for any NVIDIA RTX card not explicitly named (3080, 4080, 5090...).
  // RTX_4090 + RTX_3090 are first-class because they dominate the
  // self-hosted inference market — operators on these specifically
  // care about being identified as such.
  // Routing rule: requests with workloadType=INFERENCE can match all
  // tiers (including these three). Requests with workloadType=TRAINING
  // or MIXED hard-filter these out — consumer GPUs aren't designed
  // for sustained multi-day training loads.
  CONSUMER
  RTX_4090
  RTX_3090
}

enum NodeType {
  PROVISIONED // TokenOS provisions from data center
  BYOG        // Bring Your Own GPU
}

enum NodeStatus {
  ONLINE
  DEGRADED
  OFFLINE
  PAUSED
  MAINTENANCE
}

enum JobStatus {
  PENDING    // Job submitted, waiting for routing
  ROUTING    // A²E is deciding where to route
  ASSIGNED   // Assigned to a node/market
  RUNNING    // Job is executing
  COMPLETED  // Job finished successfully
  FAILED     // Job failed
  CANCELLED  // Job was cancelled
}

enum Market {
  INTERNAL   // TokenOS internal (premium retail rate)
  AKASH      // Akash Network (external)
  IONET      // IO.net (external)
  VASTAI     // Vast.ai (external)
  // Track 5 / M0.3: per-rental revenue under Model C 3-way split.
  // When REVENUE_SPLIT_ENABLED=true, completed rentals write an
  // Earning row with market=RENTAL containing the operator's
  // (cost + 50% net) slice. The uptime-stipend path (market=INTERNAL)
  // is suppressed when the kill switch is ON so operators don't
  // double-earn. When OFF, INTERNAL behaves exactly as before and
  // RENTAL rows are never created.
  RENTAL
}

enum JobSource {
  INTERNAL   // Job originated from TokenOS internal demand (existing behavior)
  EXTERNAL   // Job arrived via external market (Akash/IO.net/Vast.ai deployment)
}

enum ExternalDeploymentStatus {
  PENDING      // Creation initiated, awaiting confirmation from market
  ACTIVE       // Running on external market
  TERMINATING  // Delist in progress (SAFE mode grace window)
  TERMINATED   // Successfully terminated
  FAILED       // Creation or runtime failure
}

enum ExternalTerminationMode {
  SAFE   // Waited for workload completion or grace window
  FORCE  // Terminated immediately, forfeit in-flight earnings
}

// ============================================================================
// USERS & AUTH (M6)
// ============================================================================

enum UserRole {
  NODE_RUNNER
  COMPUTE_BUYER
  CUSTOMER       // Legacy — use COMPUTE_BUYER for new buyers
  ADMIN
  // Track 5 / M0.2: virtual system accounts that hold the 3-way
  // revenue split's non-operator slices. One STAKING_POOL row and one
  // TREASURY row are seeded at deploy time; splitRevenue credits them
  // through the regular creditBalance path so the ledger stays uniform.
  // They never authenticate, never appear in user-facing lists, and
  // are filtered out by the standard role-based queries.
  SYSTEM_STAKING_POOL
  SYSTEM_TREASURY
}

enum NotificationType {
  NODE_OFFLINE
  PAYOUT_SENT
  JOB_COMPLETED
  JOB_FAILED
  INVESTMENT_CONFIRMED
  INVESTMENT_PROVISIONED
  DEPLOYMENT_REQUESTED
  DEPLOYMENT_STARTED
  DEPLOYMENT_COMPLETED
  COMPUTE_REQUEST_NEW
  COMPUTE_REQUEST_APPROVED
  COMPUTE_ALLOCATED
  COMPUTE_ACTIVE
  COMPUTE_EXPIRING
  COMPUTE_COMPLETED
  COMPUTE_REJECTED
  COMPUTE_REQUEST_HELD // M2: held by auto-allocator pending admin review
  WITHDRAWAL_REQUESTED
  WITHDRAWAL_APPROVED
  WITHDRAWAL_PROCESSING
  WITHDRAWAL_COMPLETED
  WITHDRAWAL_REJECTED
  // Category C wave 1 additions
  FIRST_HEARTBEAT_RECEIVED // C5: fires once per operator when first heartbeat lands
  FIRST_EARNING            // C5: fires once per operator on first non-zero Earning row
  NODE_DEGRADED            // C4: fires when benchmark score drops >20% from prior score
  // Post-wave-2: email verification confirmation
  EMAIL_VERIFIED           // Fires once when User.emailVerified flips from false -> true
  // Track 5 / 3.A — token-billing alerts
  BURN_RATE_ALERT          // Buyer's hourly inference spend > 2x their 7-day average
  // T2.1: top-up landed notifications. Fired from all three credit
  // paths (Solana mainnet topup, Stripe checkout, admin TOPUP_ADMIN)
  // so the buyer sees a bell + web push the moment money lands.
  // Eligible for email per the existing high-priority list so
  // receipts ship even when the user isn't online.
  BALANCE_TOPUP
}

model User {
  id               String    @id @default(cuid())
  email            String?   @unique
  walletAddress    String?   @unique
  passwordHash     String?
  // role marks the user's primary identity (whichever they signed up
  // as). Kept for backward compat and for reporting. Day-to-day
  // capability checks should read isBuyer / isNodeRunner / isAdmin
  // instead, since a single account can now hold multiple roles.
  role             UserRole  @default(NODE_RUNNER)
  // Dual-identity flags. Migration backfills from role on launch:
  //   role=COMPUTE_BUYER  -> isBuyer=true
  //   role=NODE_RUNNER    -> isNodeRunner=true
  //   role=CUSTOMER       -> isBuyer=true
  //   role=ADMIN          -> isAdmin=true
  // New signups flip the right flag + leave the others false; users
  // can opt in to the other role later via Settings.
  isBuyer          Boolean   @default(false)
  isNodeRunner     Boolean   @default(false)
  isAdmin          Boolean   @default(false)
  emailVerified    Boolean   @default(false)
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?

  // Email verification
  emailVerificationToken  String?
  emailVerificationExpiry DateTime?

  // Password reset
  passwordResetToken  String?
  passwordResetExpiry DateTime?

  // M2: buyer quotas. Cap concurrent active rentals and daily spend so a
  // compromised account can't drain inventory or burn the buyer's wallet.
  // Defaults are generous enough to be invisible for legitimate users;
  // admin can tune per-user from the dashboard.
  maxConcurrentRentals  Int     @default(10)
  maxDailySpendUsd      Float   @default(10000)

  // M2: trust score for the auto-allocator. Increments on every successfully
  // completed rental (full cycle, no chargeback). Used by the eligibility
  // rules engine to decide whether a request auto-approves or holds for
  // admin review.
  successfulRentalCount Int     @default(0)
  lastRentalAt          DateTime?

  // M5.7 anti-abuse: signup IP. Used by the referral attribution path
  // to flag sock-puppet referees (same IP as the referrer) so the
  // worker can skip commission accrual on suspicious pairs. Indexed
  // because the IP check is on the hot signup path.
  signupIp         String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  nodeRunner       NodeRunner?
  notifications    Notification[]
  refreshTokens    RefreshToken[]
  computeRequests   ComputeRequest[]
  apiKeys           ApiKey[]
  ratingsGiven      Rating[]
  buyerBalance      BuyerBalance?
  pushSubscriptions PushSubscription[]

  @@index([role])
  @@index([signupIp])
}

model ApiKey {
  id          String    @id @default(cuid())
  key         String    @unique
  name        String
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions String[]  @default(["compute:read", "compute:write"])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([key])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  // Optional deep-link path the portal bell uses to navigate when the
  // user clicks the notification. e.g. '/payouts' for a payout
  // confirmation, '/buyer/requests/abc123' for a compute lifecycle
  // event. Relative paths only; never an external URL.
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ============================================================================
// NODE RUNNERS (Investors)
// ============================================================================

model NodeRunner {
  id            String   @id @default(cuid())
  name          String               // Display name
  email         String?  @unique     // Contact email
  walletAddress String   @unique     // Solana wallet for payouts

  // Link to User account (for portal login)
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id])

  // Payout preferences
  payoutThreshold  Float    @default(10.0)   // Minimum USD to trigger payout
  payoutFrequency  String   @default("WEEKLY") // DAILY, WEEKLY, MONTHLY
  payoutDayOfWeek  Int?     // 0=Sunday, 1=Monday, etc. (for WEEKLY)
  payoutDayOfMonth Int?     // 1-28 (for MONTHLY)

  // Payout mode. Controls how earnings flow from the platform to the
  // operator's wallet:
  //   AUTO       — default. Settlement worker fires when threshold +
  //                frequency conditions hit (legacy behavior).
  //   MANUAL     — earnings accumulate on the platform indefinitely;
  //                the operator clicks "Withdraw now" to trigger a
  //                payout against the unpaid balance.
  //   SCHEDULED  — accumulate until payoutScheduledAt; on/after that
  //                date the worker fires the full unpaid balance and
  //                resets mode back to AUTO.
  // Two safety nets enforced by the settlement worker regardless of
  // mode: a $50K cap on platform-held balance forces a payout, and
  // 180-day account inactivity forces a sweep so dormant balances
  // never sit forever.
  // New operators default to MANUAL — pure custodial UX. They have to
  // click Withdraw to receive funds. Existing rows pre-feature land on
  // AUTO and stay there until they actively change it; we don't migrate
  // them silently.
  payoutMode        PayoutMode  @default(MANUAL)
  payoutScheduledAt DateTime?

  // Admin-applied hard hold on payouts. While set and in the future,
  // both the settlement worker and the Withdraw Now endpoint refuse
  // to fire for this operator. Used by support during buyer disputes
  // or fraud investigations. payoutLockReason is surfaced to the
  // operator so they understand why their payouts are frozen.
  payoutLockUntil   DateTime?
  payoutLockReason  String?

  // C5 (onboarding wave 1): one-shot timestamps that gate first-X
  // celebration notifications. Set inside the heartbeat / earnings-
  // rollup hot paths using updateMany({where:{id, firstXAt:null}})
  // so concurrent writes are idempotent (Postgres row-lock wins one).
  // Once set, the FIRST_HEARTBEAT_RECEIVED / FIRST_EARNING notifications
  // never re-fire for this operator.
  firstHeartbeatAt  DateTime?
  firstEarningAt    DateTime?

  // C7 (tax wave 1): optional W-9 / tax-form data. Filled in by the
  // operator on /payouts/settings → "Tax info" card. The tax-year
  // CSV pre-fills these into the operator-header row so it's ready
  // to hand to a CPA for 1099-MISC prep. US-only fields for the first
  // iteration; W-8BEN flow is in the runbook as a future addition.
  // taxId stores raw TIN — should be encrypted at rest in a follow-up
  // (see plan's risks section). Last-4 only is displayed in the UI.
  legalName         String?
  taxId             String?
  taxIdType         TaxIdType?
  taxAddress        String?
  taxJurisdiction   String?     @default("US")
  w9SubmittedAt     DateTime?

  // C3 wave 2: operator opt-out for the Monday weekly digest email.
  // Defaulted false so new operators get the digest by default; they
  // can flip on /payouts/settings if they find it noisy. Read by the
  // weekly-digest worker as a hard skip — opted-out operators get no
  // email regardless of forecast / uptime warnings.
  digestOptedOut    Boolean     @default(false)

  // M3: reputation. reputationScore is 0-100, recomputed daily by the
  // reputation-scorer worker from uptime + ratings + completed jobs.
  // Tier is derived from score (BRONZE/SILVER/GOLD/PLATINUM thresholds).
  // availableAsSpot: opt-in to the SPOT tier marketplace (lower revenue
  // per minute, but higher utilization since SPOT requests can preempt
  // ON_DEMAND inventory shortages).
  reputationScore  Float           @default(0)
  reputationTier   ReputationTier  @default(BRONZE)
  availableAsSpot  Boolean         @default(false)
  lastScoreUpdate  DateTime?

  // M3: URL-safe slug for the public vanity profile page.
  // marketplace.tokenos.ai/operator/<slug>. Auto-generated from name.
  slug             String?  @unique

  // M5.7 / D2: 8-character invite code (base32, ambiguous-char-free).
  // Auto-generated on first NodeRunner creation. Other operators can
  // sign up with ?ref=<this-code> to attribute commission for 365 days.
  referralCode     String?  @unique

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  nodes              Node[]
  investments        Investment[]
  withdrawalRequests WithdrawalRequest[]
  ratings            Rating[]
  // M5.7: referral edges. `referralsMade` lists referees whose signups
  // attributed back to this runner. `referralReceived` is the single
  // (optional) Referral row pointing at the operator that referred this
  // runner in the first place.
  referralsMade      Referral[] @relation("ReferrerEdge")
  referralReceived   Referral?  @relation("RefereeEdge")
  // Launch-blocker #1 / BYOG: one-shot install tokens the operator
  // mints from "+ Add Node" in the portal. Each token authorizes a
  // single curl|bash install on one machine.
  installTokens      InstallToken[]

  // Internal-spend ledger. When this operator is ALSO a buyer (dual
  // identity flag) and chooses to pay for a rental from their
  // accumulated platform balance instead of with USDC, one row per
  // rental lands here. amount tracks the actual final spend so it
  // can be rebated down on early terminate without losing the audit
  // trail. Subtracted from `available` in getOperatorBalanceBreakdown.
  internalSpends     InternalSpend[]

  @@index([walletAddress])
  @@index([userId])
  @@index([reputationScore])
  @@index([slug])
  @@index([referralCode])
}

// M3: reputation tier ladder. Ordered low to high. Tier-mapping
// thresholds (env-tunable in the scorer worker):
//   PLATINUM >= 90, GOLD >= 80, SILVER >= 60, else BRONZE.
enum ReputationTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

// Payout mode for a NodeRunner. Drives the settlement worker's
// decision tree. See NodeRunner.payoutMode for the per-mode behavior
// and the $50K-cap / 180-day-inactivity safety nets.
enum PayoutMode {
  AUTO
  MANUAL
  SCHEDULED
}

// Payment source for a ComputeRequest. USDC is the default Solana
// flow (txHash points at a real on-chain transfer). INTERNAL_BALANCE
// is for dual-identity users who are also operators — they pay for a
// rental from their accumulated platform balance instead, and an
// InternalSpend row records the debit.
enum PaymentSource {
  USDC              // fresh on-chain Solana payment (txHash required)
  INTERNAL_BALANCE  // operator earnings used to fund a rental (dual-role accounts)
  BUYER_BALANCE     // pre-loaded buyer credit (see BuyerBalance + BalanceTransaction)
}

// C7 (tax wave 1): IRS taxpayer-identification-number type. Drives
// which CSV header the tax-year export uses (1099-MISC vs entity-form
// flavors). Only US individuals + entities for now; W-8BEN flow for
// non-US operators is a follow-up.
enum TaxIdType {
  SSN  // individual taxpayer
  EIN  // sole-prop or entity
}

// C2 wave 2: buyer-declared workload type on a ComputeRequest. Drives
// the allocator's tier-eligibility filter — CONSUMER / RTX_4090 /
// RTX_3090 nodes ONLY match requests with workloadType=INFERENCE.
// TRAINING and MIXED requests filter consumer tiers out entirely
// (consumer cards aren't designed for sustained multi-day loads).
//
// Existing requests pre-migration default to MIXED, preserving the
// pre-wave-2 routing semantics (they never saw consumer tiers because
// consumer tiers didn't exist).
enum WorkloadType {
  INFERENCE
  TRAINING
  MIXED
}

// Internal-spend ledger. One row per ComputeRequest where the buyer
// (who must also be a NodeRunner) chose to pay from their platform
// balance. amount mutates on early terminate to reflect the final
// accrued cost so refunds stay inside the bookkeeping ledger rather
// than flowing back through Solana. Subtracted from `available` in
// getOperatorBalanceBreakdown so the next rental sees the right
// remaining balance.
model InternalSpend {
  id                String         @id @default(cuid())
  nodeRunnerId      String
  nodeRunner        NodeRunner     @relation(fields: [nodeRunnerId], references: [id], onDelete: Cascade)
  // 1:1 with the rental that drew the funds. Indexed for the
  // operator's payouts page; queried by nodeRunnerId in hot path.
  computeRequestId  String         @unique
  amount            Float
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([nodeRunnerId])
  @@index([nodeRunnerId, createdAt])
}

// M5.7 / D2: operator referral program.
// One row per (referrer, referee) edge. status=ACTIVE during the
// 365-day commission window. After expiresAt, the daily worker stops
// accruing and the row stays for audit.
model Referral {
  id                       String          @id @default(cuid())
  code                     String          // copy of NodeRunner.referralCode at attribution time
  referrerNodeRunnerId     String
  referrer                 NodeRunner      @relation("ReferrerEdge", fields: [referrerNodeRunnerId], references: [id], onDelete: Cascade)
  refereeNodeRunnerId      String          @unique
  referee                  NodeRunner      @relation("RefereeEdge", fields: [refereeNodeRunnerId], references: [id], onDelete: Cascade)

  status                   ReferralStatus  @default(ACTIVE)

  // Window during which earnings on the referee accrue commission to the
  // referrer. Default is 365 days from createdAt; we keep this explicit
  // on the row so future policy changes do not retroactively shorten or
  // extend existing referrals.
  expiresAt                DateTime
  totalCommissionAccrued   Float           @default(0)
  lastSettledAt            DateTime?       // marks the most recent commission tick processed

  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  @@index([referrerNodeRunnerId])
  @@index([code])
  @@index([status, expiresAt])
}

enum ReferralStatus {
  ACTIVE       // accruing commission
  EXPIRED      // 365-day window elapsed
  REVOKED      // admin-revoked (abuse, dispute, sock-puppet)
}

model Investment {
  id            String           @id @default(cuid())
  nodeRunnerId  String
  nodeRunner    NodeRunner       @relation(fields: [nodeRunnerId], references: [id])

  // Investment details
  amount        Float            // Amount paid (e.g., 2500)
  currency      String           @default("USD")
  nodeCount     Int              @default(1)

  // Crypto payment details
  cryptoAmount  Float?           // Amount in crypto (e.g., SOL)
  cryptoCurrency String?         // e.g., "SOL", "USDC"
  txHash        String?          // Solana transaction hash
  txConfirmed   Boolean          @default(false)

  // What was purchased
  nodeId        String?          // Linked to node once provisioned
  gpuTier       GpuTier          // GPU tier purchased

  // Status
  status        InvestmentStatus @default(PENDING)

  // Deployment tracking (node runner → admin → data center flow)
  deploymentNote String?         // Node runner's note for the request
  sshHost        String?         // SSH host (admin fills in from data center)
  sshPort        Int?            // SSH port (default 22)
  sshUsername    String?          // SSH username
  provisionJobId String?         // Linked ProvisionJob once provisioning starts

  // Timestamps
  createdAt     DateTime         @default(now())
  confirmedAt   DateTime?        // When payment was confirmed
  deploymentRequestedAt DateTime? // When node runner requested deployment
  provisionedAt DateTime?        // When node was provisioned

  // Auto-minted BYOG install token. Created at payment-confirm time so
  // the operator gets the curl one-liner immediately on the deployment
  // detail page, no admin gate. Nullable for legacy rows + cases where
  // the auto-mint failed silently (e.g. orphan partial transaction).
  installToken  String?

  @@index([nodeRunnerId])
  @@index([status])
  @@index([txHash])
}

enum InvestmentStatus {
  PENDING                // Waiting for payment
  PAID                   // Payment received (admin-created flow)
  DEPLOYMENT_REQUESTED   // Node runner requested deployment, waiting for admin
  DEPLOYING              // Admin submitted SSH details, provisioning in progress
  PROVISIONED            // Node is set up and running
  CANCELLED              // Investment cancelled/refunded
}

// ============================================================================
// NODES
// ============================================================================

model Node {
  id            String     @id @default(cuid())
  walletAddress String     @unique
  gpuTier       GpuTier
  nodeType      NodeType
  status        NodeStatus @default(ONLINE)
  region        String?

  // Node Runner (owner/investor)
  nodeRunnerId  String?
  nodeRunner    NodeRunner? @relation(fields: [nodeRunnerId], references: [id])

  // Custom GPU info (used when gpuTier = OTHER)
  customGpuModel    String?   // e.g. "A100", "RTX 4090", "L40S"
  customRatePerHour Float?    // Custom hourly rate for OTHER tier
  customRatePerDay  Float?    // Custom daily rate for OTHER tier

  // Agent authentication
  apiKey        String?    @unique  // Node-specific API key for agent auth

  // Deletion flag - when true, agent will receive UNINSTALL command on next heartbeat
  pendingDeletion Boolean  @default(false)

  // Compute buyer allocation
  assignedComputeRequestId String?  // Which compute request this node is serving

  // M4.7: cluster membership. Set while the node is participating in a
  // multi-node cluster rental; cleared when the rental terminates and
  // the node returns to the idle pool. clusterRank is the node's
  // 0-indexed position in the cluster (rank 0 = master / head node).
  // clusterWireguardIp is a /30-sized peer address inside the cluster
  // mesh, e.g. 10.42.0.1.
  clusterId            String?
  clusterRank          Int?
  clusterWireguardIp   String?

  // Agent information
  agentVersion  String?
  currentJobId  String?
  lastCommandAt DateTime?

  // Health tracking
  lastHeartbeat DateTime   @default(now())
  missedBeats   Int        @default(0)

  // C4 (benchmarking wave 1): one-click benchmark result fields. Set
  // by POST /v1/agent/benchmark/result after the agent runs the
  // benchmark Docker image. benchmarkScore is the composite 0-100,
  // derived as a weighted blend of matmul throughput + VRAM bandwidth
  // against tier-specific baselines (see runbook for the score table).
  // NODE_DEGRADED notification fires when a new score is >20% below
  // the previous benchmarkScore. lastBenchmarkAt drives the "last run
  // X days ago" copy on the operator's node detail page.
  benchmarkScore             Float?
  benchmarkMatmulTflops      Float?
  benchmarkVramBandwidthGbs  Float?
  lastBenchmarkAt            DateTime?

  // C2 wave 2: operator-declared residential-IP marker. Lets operators
  // on home internet (no static IP, behind NAT) opt into the consumer
  // GPU tiers without being mistaken for data-center inventory. The
  // marketplace surfaces a "Home GPU" badge when this is true so
  // buyers understand the expected reliability tradeoff. Defaulted
  // false to preserve all pre-migration nodes as non-residential.
  isResidential              Boolean   @default(false)

  // #7 wave 3 (operator-set pricing): per-node operator-chosen rate
  // overriding the YieldFloor-derived default. Constrained at the
  // service layer to a band around the floor (currently ±25%, set in
  // services/pricing/operator-rate.ts) so operators cannot underprice
  // themselves into a loss OR list at a rate that puts them outside
  // the allocator's candidate window. NULL means "use YieldFloor"
  // (the pre-#7 default behavior every existing node keeps until the
  // operator opts in via the per-node Pricing card).
  operatorRatePerHour        Float?
  operatorRatePerDay         Float?
  operatorRateUpdatedAt      DateTime?

  // Track 5 / M0.1: cost-of-service inputs.
  //
  // declaredGpuSku — normalized SKU key matching GpuCostBaseline.gpuSku.
  // The cost-of-service service reads this to compute kWh draw +
  // amortized hardware per hour. Populated by:
  //   1) one-shot backfill at deploy from (gpuTier, customGpuModel)
  //   2) BYOG install handshake (agent reports lspci / nvidia-smi data)
  //   3) datacenter API provisioning response (SKU is known at order)
  // NULL means "fall back to the gpuTier-derived default baseline" —
  // splitRevenue handles this transparently so existing nodes don't
  // need a backfill before the kill switch flips.
  //
  // powerRegion — coarse region bucket matching PowerRate.region
  // ("US","EU","ASIA","OTHER"). Determines kWh price. NULL falls back
  // to PowerRate.region="GLOBAL" (a single median rate used until
  // regional inference is wired in).
  declaredGpuSku             String?
  powerRegion                String?

  // Timestamps
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  jobs                Job[]
  earnings            Earning[]
  heartbeats          Heartbeat[]
  settlements         Settlement[]
  infrastructureCosts InfrastructureCost[]
  provisionJob        ProvisionJob?
  externalDeployments ExternalDeployment[]

  @@index([status])
  @@index([gpuTier])
  @@index([lastHeartbeat])
  @@index([nodeRunnerId])
}

model Heartbeat {
  id          String   @id @default(cuid())
  nodeId      String
  node        Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  // GPU Metrics (optional)
  gpuUtilization  Float?   // 0-100%
  gpuTemperature  Float?   // Celsius
  gpuMemoryUsed   Float?   // GB
  gpuMemoryTotal  Float?   // GB

  timestamp   DateTime @default(now())

  @@index([nodeId, timestamp])
}

// ============================================================================
// BYOG INSTALL TOKENS (launch-blocker #1)
// ============================================================================

// One-shot token authorizing a single BYOG node install. Issued from the
// operator portal ("+ Add Node"), embedded in the install.sh curl URL,
// consumed when the agent first calls /v1/byog/claim. After claim, the
// token row is marked consumed and cannot be re-used. Unconsumed tokens
// expire after `expiresAt` (default 7 days from creation).
model InstallToken {
  id                String      @id @default(cuid())
  // URL-safe random string (~32 chars). The value the operator pastes
  // into the curl one-liner; never re-displayed in the portal after
  // creation, treat like a password.
  token             String      @unique

  // Owner
  nodeRunnerId      String
  nodeRunner        NodeRunner  @relation(fields: [nodeRunnerId], references: [id], onDelete: Cascade)

  // Region operator pre-selected at mint time. Pre-populates Node.region
  // so the install script never has to prompt for it.
  region            String?

  // Lifecycle. consumedByNodeId is the Node row created from this token.
  consumedAt        DateTime?
  consumedByNodeId  String?     @unique
  expiresAt         DateTime
  createdAt         DateTime    @default(now())

  @@index([nodeRunnerId])
  @@index([expiresAt])
}

// ============================================================================
// JOBS
// ============================================================================

model Job {
  id            String    @id @default(cuid())
  deploymentId  String    // External reference from TokenOS

  // Assignment
  nodeId        String?
  node          Node?     @relation(fields: [nodeId], references: [id])

  // Routing decision
  market        Market?
  ratePerHour   Float?

  // Job details
  gpuTier       GpuTier
  status        JobStatus @default(PENDING)

  // Origin — whether this job came from internal TokenOS demand or an external market
  source               JobSource           @default(INTERNAL)
  externalDeploymentId String?
  externalDeployment   ExternalDeployment? @relation(fields: [externalDeploymentId], references: [id])

  // Timing
  requestedAt   DateTime  @default(now())
  routedAt      DateTime?
  startedAt     DateTime?
  completedAt   DateTime?

  // Duration and earnings
  durationSeconds Int?
  earnings        Float?    // Revenue from this job
  cost            Float?    // Cost to execute (market rate or external fees)
  profit          Float?    // earnings - cost

  // Error tracking
  errorMessage  String?
  retryCount    Int       @default(0)

  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  routingLog    RoutingLog?

  @@index([status])
  @@index([deploymentId])
  @@index([nodeId])
  @@index([market])
  @@index([requestedAt])
  @@index([source])
  @@index([externalDeploymentId])
}

// ============================================================================
// ROUTING DECISIONS
// ============================================================================

model RoutingLog {
  id              String   @id @default(cuid())
  jobId           String   @unique
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // Decision
  selectedMarket  Market
  selectedRate    Float    // Rate per hour that was selected

  // Rates at decision time
  internalRate    Float?
  akashRate       Float?
  ionetRate       Float?
  vastaiRate      Float?

  // Yield floor
  yieldFloor          Float
  yieldFloorApplied   Boolean  @default(false)

  // Reasoning
  reason          String   // Human-readable explanation

  // Decision metadata
  decisionTimeMs  Int?     // How long the decision took

  timestamp       DateTime @default(now())

  @@index([selectedMarket])
  @@index([timestamp])
}

// ============================================================================
// MARKET RATES
// ============================================================================

model MarketRate {
  id          String   @id @default(cuid())
  market      Market
  gpuTier     GpuTier
  ratePerHour Float
  ratePerDay  Float
  available   Boolean  @default(true)

  fetchedAt   DateTime @default(now())

  @@unique([market, gpuTier])
  @@index([market, gpuTier, fetchedAt])
}

model MarketRateHistory {
  id          String   @id @default(cuid())
  market      Market
  gpuTier     GpuTier
  ratePerHour Float
  ratePerDay  Float

  fetchedAt   DateTime @default(now())

  @@index([market, gpuTier, fetchedAt])
}

// ============================================================================
// EARNINGS
// ============================================================================

model Earning {
  id            String   @id @default(cuid())
  nodeId        String
  node          Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  date          DateTime @db.Date
  market        Market

  gpuSeconds    Int      @default(0)
  earnings      Float    @default(0)
  jobCount      Int      @default(0)

  // Cooling-off period. Earnings sit in "pending" state until availableAt
  // passes, then become withdrawable. Default 12h after creation gives
  // the platform a buyer-dispute window without making us legally
  // custodial for long periods. Admin can manually shift availableAt
  // earlier (release on appeal) or later (extend hold during a dispute).
  // The settlement engine and "Withdraw now" path filter on availableAt
  // so locked funds physically can't leave the platform.
  availableAt   DateTime @default(dbgenerated("CURRENT_TIMESTAMP + INTERVAL '12 hours'"))

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([nodeId, date, market])
  @@index([nodeId, date])
  @@index([date])
  @@index([availableAt])
}

