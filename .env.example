# A²E Engine Environment Variables

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/a2e?schema=public"

# Redis (for BullMQ job queue and caching)
REDIS_URL="redis://localhost:6379"

# API Authentication
API_KEY=your-secret-api-key-here

# External Market Adapters
AKASH_ENABLED=true
AKASH_API_ENDPOINT=https://api.akash.network

IONET_ENABLED=false
IONET_API_ENDPOINT=

# Rate Fetching
RATE_CACHE_TTL_MS=60000
RATE_FETCH_INTERVAL_MS=60000

# Node Health
HEARTBEAT_TIMEOUT_MS=90000
HEARTBEAT_CHECK_INTERVAL_MS=10000

# Logging
LOG_LEVEL=info
