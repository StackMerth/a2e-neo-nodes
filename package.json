{
  "name": "a2e-engine",
  "version": "1.0.0",
  "private": true,
  "description": "A²E (Arbitrage & Orchestration Engine) for TokenOS",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @a2e/database generate",
    "db:migrate": "pnpm --filter @a2e/database migrate",
    "db:studio": "pnpm --filter @a2e/database studio",
    "seed:test": "pnpm --filter @a2e/api seed:test",
    "seed:keep-alive": "pnpm --filter @a2e/api seed:keep-alive-only",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "@scure/base": "1.2.6",
      "@scure/bip39": "^1.6.0",
      "@noble/hashes": "^1.8.0",
      "@noble/curves": "^1.8.0",
      "@noble/ciphers": "^1.2.0"
    }
  }
}
