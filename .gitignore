# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
.next/
.turbo/
*.tsbuildinfo

# C6 wave 2: next-pwa generates the service worker + workbox runtime
# at build time. Source of truth lives in the manifest + scripts; the
# emitted JS is per-build and shouldn't be committed.
apps/portal/public/sw.js
apps/portal/public/sw.js.map
apps/portal/public/workbox-*.js
apps/portal/public/workbox-*.js.map
apps/portal/public/fallback-*.js

# Test
coverage/

# Env / secrets — only commit .env.example
.env
.env.local
.env.production
.env.development
.env.test
.env*.local

# Wallet keys / certs — never commit these
*.pem
*.key
*.crt
wallet*.json
keypair*.json
*.priv

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local dev databases
*.sqlite
*.sqlite3
*.db

# Claude Code local cache (per-developer, not shared)
.claude/
